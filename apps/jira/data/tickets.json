      "self": "http://localhost:8080/rest/api/3/issue/TODO-4",
      "fields": {
        "summary": "As a user I can filter todos by status (All, Active, Completed)",
        "description": {
          "type": "doc",
          "version": 1,
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Users should be able to filter the displayed todo list using the three filter buttons at the top of the list: All, Active, and Completed."
                }
              ]
            },
            {
              "type": "paragraph",
              "content": [{"type": "text", "text": "Acceptance Criteria:", "marks": [{"type": "strong"}]}]
            },
            {
              "type": "orderedList",
              "content": [
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-1: Three filter buttons are visible: 'All', 'Active', and 'Completed'"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-2: 'All' is the default selected filter and shows every todo regardless of status"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-3: Selecting 'Active' shows only todos where completed = false"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-4: Selecting 'Completed' shows only todos where completed = true"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-5: The currently active filter button is visually highlighted (active CSS class applied)"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-6: Adding a new todo while a filter is active does not reset the filter selection"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-7: When a filtered view is empty (no matching todos), the empty-state message is displayed"}]}]}
              ]
            }
          ]
        },
