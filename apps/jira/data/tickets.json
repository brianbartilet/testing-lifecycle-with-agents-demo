      "key": "TODO-1",
      "self": "http://localhost:8080/rest/api/3/issue/TODO-1",
      "fields": {
        "summary": "As a user I can create a new todo item with a title",
        "description": {
          "type": "doc",
          "version": 1,
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Users should be able to add a new todo by entering text in the input field and clicking the Add button or pressing Enter. The todo should appear immediately in the list."
                }
              ]
            },
            {
              "type": "paragraph",
              "content": [{"type": "text", "text": "Acceptance Criteria:", "marks": [{"type": "strong"}]}]
            },
            {
              "type": "orderedList",
              "content": [
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-1: The todo input field is visible on the page on load"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-2: User can type a todo title between 1 and 200 characters inclusive"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-3: Clicking the 'Add' button submits the form and creates the todo"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-4: Pressing the Enter key inside the input field also creates the todo"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-5: Submitting an empty input is rejected — no todo is created and an error is shown"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-6: The newly created todo appears at the top of the todo list immediately"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-7: The input field is cleared after a todo is successfully added"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-8: The todo is persisted via POST /todos and survives a page refresh"}]}]}
              ]
            }
          ]
        },
        "status": {"name": "Ready for Testing", "id": "10003"},
        "priority": {"name": "High", "id": "2"},
        "issuetype": {"name": "Story", "id": "10001"},
