    {
      "id": "10003",
      "key": "TODO-3",
      "self": "http://localhost:8080/rest/api/3/issue/TODO-3",
      "fields": {
        "summary": "As a user I can delete a todo item",
        "description": {
          "type": "doc",
          "version": 1,
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "Users should be able to permanently remove a todo item from the list by clicking the Delete button."
                }
              ]
            },
            {
              "type": "paragraph",
              "content": [{"type": "text", "text": "Acceptance Criteria:", "marks": [{"type": "strong"}]}]
            },
            {
              "type": "orderedList",
              "content": [
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-1: Every todo item displays a Delete button"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-2: Clicking Delete removes the todo from the visible list immediately (no page reload required)"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-3: The deletion is sent to the API via DELETE /todos/{id} and returns HTTP 204"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-4: After deletion, a GET /todos/{id} request for the same ID returns HTTP 404"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-5: Deleting a todo does not affect any other todo items in the list"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-6: Both active and completed todos can be deleted"}]}]}
              ]
            }
          ]
        },
