    {
      "id": "10005",
      "key": "TODO-5",
      "self": "http://localhost:8080/rest/api/3/issue/TODO-5",
      "fields": {
        "summary": "Todo REST API must return correct HTTP status codes for all operations",
        "description": {
          "type": "doc",
          "version": 1,
          "content": [
            {
              "type": "paragraph",
              "content": [
                {
                  "type": "text",
                  "text": "The backend API must follow REST conventions and return the appropriate HTTP status codes for every operation and error scenario."
                }
              ]
            },
            {
              "type": "paragraph",
              "content": [{"type": "text", "text": "Acceptance Criteria:", "marks": [{"type": "strong"}]}]
            },
            {
              "type": "orderedList",
              "content": [
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-1: GET /todos returns 200 OK with a JSON array (empty array when no todos exist)"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-2: POST /todos with a valid body returns 201 Created with the new todo object"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-3: GET /todos/{id} returns 200 OK with the matching todo object"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-4: GET /todos/{id} returns 404 Not Found when the ID does not exist"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-5: PUT /todos/{id} with a valid body returns 200 OK with the updated todo object"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-6: PUT /todos/{id} returns 404 Not Found when the ID does not exist"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-7: DELETE /todos/{id} returns 204 No Content on successful deletion"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-8: DELETE /todos/{id} returns 404 Not Found when the ID does not exist"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-9: POST /todos with an empty title returns 422 Unprocessable Entity"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-10: POST /todos with a title longer than 200 characters returns 422 Unprocessable Entity"}]}]},
                {"type": "listItem", "content": [{"type": "paragraph", "content": [{"type": "text", "text": "AC-11: GET /health returns 200 OK with {status: 'ok'} at all times"}]}]}
              ]
            }
          ]
        },
        "status": {"name": "Ready for Testing", "id": "10003"},
        "priority": {"name": "High", "id": "2"},
        "issuetype": {"name": "Story", "id": "10001"},
        "assignee": {"displayName": "Jane Dev", "emailAddress": "jane@example.com"},
        "reporter": {"displayName": "Product Owner", "emailAddress": "po@example.com"},
        "labels": ["api", "backend"],
        "components": [{"name": "Backend API"}],
        "fixVersions": [{"name": "v1.0"}],
        "created": "2024-01-15T09:20:00.000+0000",
        "updated": "2024-01-20T14:50:00.000+0000",
        "comment": {
          "comments": [
            {
              "author": {"displayName": "Developer"},
              "body": "AC-9 and AC-10: FastAPI returns 422 automatically via Pydantic validation. The response body will include a 'detail' array describing the validation errors.",
              "created": "2024-01-19T14:00:00.000+0000"
            },
            {
              "author": {"displayName": "QA Lead"},
              "body": "AC-11: include the health check in the smoke test suite so CI fails fast if the service is down.",
              "created": "2024-01-20T09:15:00.000+0000"
            }
          ]
        }
      }
    }
  ]
